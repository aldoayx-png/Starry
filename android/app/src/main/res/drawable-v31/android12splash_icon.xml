<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ splash icon sizing:
  Inset the existing bitmap so it doesn't render oversized.
-->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:insetLeft="96dp"
    android:insetTop="96dp"
    android:insetRight="96dp"
    android:insetBottom="96dp">

    <bitmap
        android:src="@drawable/android12splash"
        android:gravity="center" />
</inset>

